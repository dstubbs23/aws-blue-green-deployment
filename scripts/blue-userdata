#!/bin/bash
dnf update -y
dnf install -y httpd

TOKEN=$(curl -X PUT "http://169.254.169.254/latest/api/token" \
  -H "X-aws-ec2-metadata-token-ttl-seconds: 21600")

INSTANCE_ID=$(curl -s -H "X-aws-ec2-metadata-token: $TOKEN" \
  http://169.254.169.254/latest/meta-data/instance-id)

ENV_NAME="Blue Environment"
VERSION="v1"
DESCRIPTION="This is the current production environment (BLUE) serving live traffic."

cat <<EOF > /var/www/html/index.html
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>$ENV_NAME • $VERSION</title>
  <style>
    body {
      margin: 0;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: linear-gradient(135deg, #0f172a, #1e293b);
      color: #e5e7eb;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .card {
      background: rgba(15, 23, 42, 0.9);
      border-radius: 16px;
      padding: 32px 40px;
      max-width: 540px;
      width: 100%;
      box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
      border: 1px solid rgba(148, 163, 184, 0.3);
    }
    .pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 4px 12px;
      border-radius: 999px;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      background: rgba(59, 130, 246, 0.18);
      border: 1px solid rgba(59, 130, 246, 0.6);
      color: #bfdbfe;
    }
    h1 {
      font-size: 26px;
      margin: 14px 0 4px;
    }
    .version {
      font-size: 14px;
      color: #9ca3af;
      margin-bottom: 18px;
    }
    .description {
      font-size: 14px;
      line-height: 1.6;
      color: #d1d5db;
      margin-bottom: 20px;
    }
    .meta {
      display: flex;
      flex-direction: column;
      gap: 8px;
      font-size: 13px;
      color: #9ca3af;
      padding: 12px 14px;
      border-radius: 12px;
      background: rgba(15, 23, 42, 0.9);
      border: 1px dashed rgba(148, 163, 184, 0.6);
    }
    .label {
      font-weight: 500;
      color: #e5e7eb;
    }
    .footer {
      margin-top: 18px;
      font-size: 12px;
      color: #6b7280;
    }
    .dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: #22c55e;
    }
    .pill-content {
      display: flex;
      align-items: center;
      gap: 6px;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="pill">
      <div class="pill-content">
        <span class="dot"></span>
        <span>ACTIVE ENVIRONMENT</span>
      </div>
    </div>
    <h1>$ENV_NAME</h1>
    <div class="version">Application Version: <strong>$VERSION</strong></div>

    <div class="description">
      $DESCRIPTION
    </div>

    <div class="meta">
      <div><span class="label">Instance ID:</span> $INSTANCE_ID</div>
      <div><span class="label">Deployment Pattern:</span> Blue-Green / Rolling Demo</div>
      <div><span class="label">Served via:</span> Auto Scaling Group behind an Application Load Balancer</div>
    </div>

    <div class="footer">
      Refresh this page to see requests move across instances during deployments.
    </div>
  </div>
</body>
</html>
EOF

systemctl enable httpd
systemctl start httpd
